# 2Captcha API key (https://2captcha.com). Не обязателен — без него капчу нужно решать вручную в браузере
API_KEY_2CAPTCHA=

# Web.de credentials
WEBDE_EMAIL=your_email@web.de
WEBDE_PASSWORD=your_password

# Kleinanzeigen (login/kleinanzeigen_login.py) — локально с .env
# KLEINANZEIGEN_EMAIL=you@example.com
# KLEINANZEIGEN_PASSWORD=your_password
# KLEINANZEIGEN_LOGIN_URL=https://www.kleinanzeigen.de/m-einloggen.html?targetUrl=/
# Long-poll SMS (ручной запуск с админкой):
# KLEINANZEIGEN_API_BASE_URL=... KLEINANZEIGEN_LEAD_ID=... WORKER_SECRET=...
# KLEINANZEIGEN_SMS_POLL_TIMEOUT_SEC=230
#
# Режим лида (сервер сам вызывает при Auto-script Klein): login/klein_simulation_api.py
# Креды: GET /api/lead-credentials — для brand klein отдаются emailKl/passwordKl как email/password.
# Результат: POST /api/webde-login-result (как у WEB.DE).
#
# Klein-оркестрация (почта WEB.DE → фильтры → сброс пароля Klein, login/lead_simulation_api.py):
# По умолчанию: только emailKl → m-passwort-vergessen → Papierkorb → ссылка → новый пароль → вход (SMS при необходимости).
# KLEIN_RESET_DEBUG=1 — PNG+HTML каждого шага в login/klein_reset_debug/
# KLEIN_RESET_MAIL_WAIT_SEC=180 — ожидание письма в корзине
# KLEIN_RESET_FORGOT_URL=https://www.kleinanzeigen.de/m-passwort-vergessen.html
# KLEIN_RESET_KLEIN_SEPARATE_BROWSER=1 — второй Chromium без куков почты для Klein (ссылка сброса открывается там через URL из письма)
# KLEIN_RESET_KLEIN_BROWSER_NO_PROXY=1 — у этого второго браузера без прокси
# KLEIN_ORCH_LEGACY_KLEIN_LOGIN=1 — старый сценарий: ждать passwordKl и обычный вход ULP
# После mail_ready_klein браузер закрывается и ждём только API (emailKl); потом снова открывается с куками — удобно для 100+ лидов и долгого ожидания.
# KLEIN_ORCH_WAIT_EMAIL_SEC=3600 — ждать emailKl до часа (пример)
# KLEIN_ORCH_CLOSE_BROWSER_FOR_EMAILKL_WAIT=0 — не закрывать браузер на время опроса (отладка / старое поведение)

# Локальный тест фильтров (login/test_mail_filters_local.py): можно положить в отдельный файл .env.local (в gitignore)
# WEBDE_TEST_EMAIL=...
# WEBDE_TEST_PASSWORD=...

# Proxy for CaptchaFox (required by 2Captcha for CaptchaFox). Format: type://user:pass@host:port or host:port
# Examples: http://user:pass@1.2.3.4:8080  or  1.2.3.4:8080
PROXY=

# Optional: direct login form URL (e.g. auth.web.de with state). Used when DIRECT_AUTH=true.
# Example: WEBDE_AUTH_URL=https://auth.web.de/login?prompt=none&state=...
# WEBDE_AUTH_URL=

# Optional: сразу открывать форму входа auth.web.de, без anmelden.web.de и окна согласия (true/false)
DIRECT_AUTH=true

# При неверном пароле из accounts.txt скрипт пробует пароли из password.txt (по одному на строку)
# PASSWORD_FILE=password.txt

# Окно Playwright (headed): не больше этого размера, пропорции сохраняются (по умол. 1280×720)
# WEBDE_PLAYWRIGHT_VIEWPORT_MAX_WIDTH=1280
# WEBDE_PLAYWRIGHT_VIEWPORT_MAX_HEIGHT=720

# Прокси для браузера: файл proxy.txt (HTTP), по одному на строку.
# Форматы: host:port:login:password  |  host:port@login:password  |  http://login:pass@host:port
# 1-й аккаунт — 1-й прокси, 2-й — 2-й, 3-й — 1-й и т.д.
# PROXY_FILE=proxy.txt
#
# WEB.DE (вход почты, браузер ③): login/proxy.txt (или текст в админке при WEBDE_PROXY_FROM_ADMIN=1).
# Klein (браузер ②, klein_ip_probe, kleinanzeigen_login): login/proxy_klein.txt — первая строка.
# Переопределить путь: KLEIN_PROXY_FILE=/abs/path/to/klein-proxies.txt
#
# klein_ip_probe / run_klein_orch_guarded.sh: опционально тот же сценарий, что прогон forgot (ввод email + Senden),
# чтобы ловить IP-Sperre после отправки формы: KLEIN_IP_PROBE_FORGOT_EMAIL=klein@example.com
# KLEIN_IP_PROBE_AFTER_SUBMIT_SEC=20
# Куки Klein: Netscape .txt (табы) или JSON-массив экспорта — только домены *kleinanzeigen.de*.
# KLEIN_IP_PROBE_COOKIES_FILE=/path/to/cookies.json
# KLEIN_ISOLATED_NETSCAPE_COOKIES_FILE=/path/to/cookies.json

# Автовход (lead_simulation_api.py): макс. попыток перебора прокси+отпечаток на один лид (по умолчанию 5).
# По умолчанию в коде 5; без лимита (круги по сетке): WEBDE_LOGIN_MAX_ATTEMPTS=0
# WEBDE_LOGIN_MAX_ATTEMPTS=5

# Папка для куков. Файлы называются по email (например cookies/user_at_web.de.json).
# COOKIES_DIR=cookies

# Параллельных потоков при нескольких аккаунтах в accounts.txt (по умолчанию 3)
# PARALLEL_WORKERS=3

# Optional: headless browser (true/false). false = видно все шаги в браузере в реальном времени
HEADLESS=false

# После входа не закрывать окно сразу — сообщение в терминале и ожидание Enter (headed). WEB.DE + Klein + Klein-orch.
# KEEP_BROWSER_OPEN=1

# Optional: использовать установленный Google Chrome вместо Chromium (меньше шансов, что сайт определит автоматизацию)
USE_CHROME=true

# Режим «реального браузера» (аналог kleinanzeigen-bot: свой профиль или уже открытый Chrome). Только Chromium.
# Подключение по CDP к Chrome, запущенному вручную с --remote-debugging-port=9222:
# WEBDE_PLAYWRIGHT_CDP_ENDPOINT=http://127.0.0.1:9222
# или короче:
# WEBDE_CHROME_REMOTE_DEBUGGING_PORT=9222
# Постоянный профиль (Playwright launch_persistent_context):
# WEBDE_CHROME_USER_DATA_DIR=/path/to/chrome-profile-dir
# Явный бинарник Chrome/Edge (если не нужен channel=chrome):
# WEBDE_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Если заданы и CDP, и USER_DATA_DIR — используется CDP.

# Изолированный браузер Klein (②): по умолчанию эфемерный launch (как klein_ip_probe), без USER_DATA_DIR.
# Постоянный профиль только явно:
# KLEIN_ISOLATED_USE_PERSISTENT_PROFILE=1
# KLEIN_ISOLATED_CHROME_USER_DATA_DIR=/path/to/klein-chrome-profile
# KLEIN_ISOLATED_BROWSER_EXECUTABLE=
# CDP только для Klein:
# KLEIN_ISOLATED_PLAYWRIGHT_CDP_ENDPOINT=http://127.0.0.1:9223
# KLEIN_ISOLATED_CHROME_REMOTE_DEBUGGING_PORT=9223

# Подсветка: красная метка там, куда скрипт кликает и двигает мышь (для отладки капчи). true/false
SHOW_CLICKS=true
